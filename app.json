{
  "expo": {
    "name": "PulsePilot",
    "slug": "pulsepilot",
    "scheme": "pulsepilot",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F4EFE5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulsepilot.app"
    },
    "android": {
      "package": "com.pulsepilot.app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7612126-4ae4-4d78-8675-aefeee3c73de"
      }
    },
    "owner": "sandmanactual"
  }
}
